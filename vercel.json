{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "buildCommand": "composer install --no-dev --optimize-autoloader",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_STORAGE": "/tmp",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "array",
    "LOG_CHANNEL": "stderr"
  }
}